<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Chromeless DayNight theme: follows the system light/dark mode. The home
         background and cards swap automatically via the drawable-night variants. -->
    <style name="Theme.MG4SimpleLauncher" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/bg_home</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="colorAccent">@color/accent</item>
    </style>

    <!-- Drawer sits on a translucent scrim over the home wallpaper. -->
    <style name="Theme.MG4SimpleLauncher.Drawer" parent="Theme.MG4SimpleLauncher">
        <item name="android:windowBackground">@color/drawer_background</item>
    </style>
</resources>
