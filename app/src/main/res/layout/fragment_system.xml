<?xml version="1.0" encoding="utf-8"?>
<!-- Carousel page 2: live system information, refreshed while the page is visible.
     All values are read without dangerous permissions. Landscape (MG4 head unit). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:baselineAligned="false"
    android:padding="@dimen/screen_padding">

    <!-- Device -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginEnd="@dimen/card_gap"
        android:background="@drawable/smallcard_selector"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/info_card_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sys_device"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/small_card_label_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_device_body"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="6dp"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/info_card_body_size" />
    </LinearLayout>

    <!-- Memory -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginEnd="@dimen/card_gap"
        android:background="@drawable/smallcard_selector"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/info_card_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sys_memory"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/small_card_label_size"
            android:textStyle="bold" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_memory_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/sys_value_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sys_used_total"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/info_card_body_size" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- Storage -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginEnd="@dimen/card_gap"
        android:background="@drawable/smallcard_selector"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/info_card_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sys_storage"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/small_card_label_size"
            android:textStyle="bold" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_storage_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/sys_value_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sys_free_total"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/info_card_body_size" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- Network -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/smallcard_selector"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/info_card_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sys_network"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/small_card_label_size"
            android:textStyle="bold" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_network_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/sys_value_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_network_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/info_card_body_size" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>
</LinearLayout>
